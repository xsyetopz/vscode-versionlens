{
  "name": "vscode-versionlens",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "native:build": "cargo build --workspace",
    "native:test": "cargo test --workspace",
    "typecheck": "bunx tsc --noEmit -p packages/vscode-extension/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@types/vscode": "^1.75.0",
    "typescript": "6.0.3"
  }
}
