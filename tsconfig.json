{
  "include": [
    "./src",
    "./src/infrastructure/providers/**/index.ts",
    "./test",
  ],
  "compilerOptions": {
    "strict": false,
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "test/*": [
        "./test/*",
        "./test/*/index.test"
      ],
      "test/unit/infrastructure/providers/*": [
        "./src/infrastructure/providers/*/test/index.test"
      ],
      "#domain/*": [
        "./src/domain/*/index"
      ],
      "#infrastructure/*": [
        "./src/infrastructure/*/index"
      ],
      "#providers/*": [
        "./src/infrastructure/providers/*/src/index"
      ],
      "#extension": [
        "./src/presentation.extension/index"
      ]
    }
  }
}