{
  "include": [
    "./src",
    "./test",
  ],
  "compilerOptions": {
    "strict": false,
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "#test/utils": [
        "./test/unit/utils.ts",
      ],
      "#test/unit/providers/*": [
        "./src/domain/providers/*/test/index.test"
      ],
      "#domain/*": [
        "./src/domain/*/index"
      ],
      "#domain/providers/*": [
        "./src/domain/providers/*/src/index"
      ],
      "#infrastructure/*": [
        "./src/infrastructure/*/index"
      ],
      "#extension": [
        "./src/presentation.extension/index"
      ]
    }
  }
}