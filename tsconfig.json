{
  "include": [
    "./types",
    "./src",
    "./test",
  ],
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "rootDir": ".",
    "paths": {
      "#test/utils": [
        "./test/unit/utils.ts",
      ],
      "#domain": [
        "./src/domain/index"
      ],
      "#domain/*": [
        "./src/domain/*/index"
      ],
      "#domain/providers/*": [
        "./src/domain/providers/*/index"
      ],
      "#extension": [
        "./src/extension/index"
      ],
      "#extension/*": [
        "./src/extension/*/index"
      ]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./types"
    ],
    "types": [
      "node"
    ]
  },
}