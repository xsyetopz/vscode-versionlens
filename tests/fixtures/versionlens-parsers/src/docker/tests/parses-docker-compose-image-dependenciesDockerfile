
services:
  web:
    image: node:20
  api:
    image: ghcr.io/org/app:1.2.3
  mcr:
    image: mcr.microsoft.com/dotnet/runtime:9.0
  data:
    image: postgres
  digest:
    image: ubuntu@sha256:def456
  image-number:
    image: 123456
  worker:
    build: .
  context-default:
    build:
      context: ./ctx
  custom:
    build:
      context: .
      dockerfile: custom.dockerfile
  built-image:
    image: example/app:1.0
    build:
      context: ./app
      dockerfile: Dockerfile.prod
  bare-build:
    build: backend
  bare-context:
    build:
      context: service
  empty:
    image: ''
  malformed:
    image: :20
